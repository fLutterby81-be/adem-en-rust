@charset "utf-8";

:root { --bg-1: #0f2027; --bg-2: #203a43; --bg-3: #2c5364; --accent: #64d8cb; --text: #ffffff; --panel-bg: rgba(255,255,255,0.08); --circle-border: rgba(255,255,255,0.4); --circle-gradient-1: rgba(255,255,255,0.15); --circle-gradient-2: rgba(255,255,255,0.05); --btn-bg: rgba(255,255,255,0.1); --shadow: rgba(0,0,0,0.2); --gold: #ffd700; --silver: #c0c0c0; }

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(135deg,var(--bg-1),var(--bg-2),var(--bg-3)); min-height: 100vh; color: var(--text); display: flex; flex-direction: column; align-items: center; padding: 20px; transition: background 1s; }

h1 { margin: 15px 0px 5px; font-weight: 300; letter-spacing: 3px; font-size: 2rem; text-shadow: rgba(0, 0, 0, 0.2) 0px 2px 10px; }

.subtitle { font-size: 1rem; opacity: 0.8; margin-bottom: 12px; font-weight: 300; }

.top-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 12px; flex-wrap: wrap; justify-content: center; }

.theme-selector { display: flex; gap: 10px; }

.theme-dot { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; transition: transform 0.3s, border-color 0.3s; box-shadow: rgba(0, 0, 0, 0.3) 0px 2px 8px; }

.theme-dot:hover { transform: scale(1.15); }

.theme-dot.active { border-color: rgb(255, 255, 255); transform: scale(1.2); }

.sound-toggle { display: flex; align-items: center; gap: 8px; background: var(--btn-bg); border: 1px solid rgba(255, 255, 255, 0.3); color: rgb(255, 255, 255); padding: 8px 16px; border-radius: 25px; cursor: pointer; font-size: 0.9rem; transition: 0.3s; backdrop-filter: blur(5px); user-select: none; }

.sound-toggle:hover { background: rgba(255, 255, 255, 0.2); }

.sound-toggle.active { background: rgba(255, 255, 255, 0.25); border-color: rgb(255, 255, 255); }

.nav-tabs { display: flex; gap: 8px; margin-bottom: 18px; }

.nav-tab { background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); color: rgb(255, 255, 255); padding: 10px 28px; border-radius: 30px; cursor: pointer; font-size: 0.95rem; transition: 0.3s; backdrop-filter: blur(5px); }

.nav-tab:hover { background: rgba(255, 255, 255, 0.18); }

.nav-tab.active { background: rgba(255, 255, 255, 0.3); border-color: rgb(255, 255, 255); font-weight: 600; }

.view { width: 100%; max-width: 480px; display: none; flex-direction: column; align-items: center; }

.view.active { display: flex; }

.technique-selector { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; }

.technique-btn { background: var(--btn-bg); border: 1px solid rgba(255, 255, 255, 0.3); color: rgb(255, 255, 255); padding: 12px 22px; border-radius: 25px; cursor: pointer; transition: 0.3s; font-size: 0.95rem; backdrop-filter: blur(5px); }

.technique-btn:hover, .technique-btn.active { background: rgba(255, 255, 255, 0.25); border-color: rgb(255, 255, 255); transform: translateY(-2px); }

.main-stage { position: relative; width: 300px; height: 300px; display: flex; justify-content: center; align-items: center; margin: 8px 0px; }

.orb { position: absolute; border-radius: 50%; background: radial-gradient(circle,var(--circle-gradient-1),var(--circle-gradient-2)); border: 3px solid var(--circle-border); width: 110px; height: 110px; transition: transform 0.1s linear, box-shadow 0.3s; display: flex; justify-content: center; align-items: center; box-shadow: 0 0 40px var(--circle-gradient-1); }

.orb-face { font-size: 2.5rem; transition: transform 0.3s; filter: drop-shadow(rgba(0, 0, 0, 0.3) 0px 2px 4px); }

.orb-breathing .orb-face { animation: 2s ease-in-out 0s infinite normal none running gentleBob; }

@keyframes gentleBob { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-5px); }
}

.timer-ring { position: absolute; width: 260px; height: 260px; border-radius: 50%; border: 3px solid rgba(255, 255, 255, 0.15); }

.timer-progress { position: absolute; width: 260px; height: 260px; border-radius: 50%; border-width: 3px; border-style: solid; border-right-color: transparent; border-bottom-color: transparent; border-left-color: transparent; border-image: initial; border-top-color: var(--accent); transition: transform 0.1s linear; }

.timer-display { font-size: 3.5rem; font-weight: 200; margin: 8px 0px; min-height: 70px; font-variant-numeric: tabular-nums; color: var(--accent); text-shadow: rgba(100, 216, 203, 0.3) 0px 0px 20px; }

.instruction { font-size: 1.2rem; font-weight: 400; margin-bottom: 6px; text-align: center; max-width: 420px; min-height: 30px; }

.phase-label { font-size: 0.9rem; opacity: 0.7; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 2px; }

.controls { display: flex; gap: 15px; margin-bottom: 10px; }

.control-btn { background: rgb(255, 255, 255); color: var(--bg-1); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 16px 40px; border-radius: 50px; font-size: 1.05rem; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; font-weight: 700; letter-spacing: 1px; box-shadow: 0 4px 15px var(--shadow); }

.control-btn:hover { transform: translateY(-3px); box-shadow: 0 8px 25px var(--shadow); }

.control-btn:active { transform: scale(0.95); }

.cycle-counter { font-size: 1rem; opacity: 0.8; margin: 8px 0px; }

.mini-streak { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; opacity: 0.85; margin-bottom: 10px; }

.info-panel { background: var(--panel-bg); border-radius: 20px; padding: 22px; width: 100%; margin-top: 16px; line-height: 1.7; font-size: 0.97rem; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }

.info-panel h3 { margin-bottom: 10px; font-weight: 500; font-size: 1.15rem; color: var(--accent); }

.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; width: 100%; margin-bottom: 18px; }

.stat-card { background: var(--panel-bg); border-radius: 16px; padding: 18px 10px; text-align: center; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); transition: transform 0.2s; }

.stat-card:hover { transform: translateY(-3px); }

.stat-number { font-size: 2rem; font-weight: 300; color: var(--accent); display: block; margin-bottom: 4px; }

.stat-label { font-size: 0.85rem; opacity: 0.85; }

.week-chart { width: 100%; background: var(--panel-bg); border-radius: 20px; padding: 20px; margin-bottom: 18px; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }

.week-chart h4 { margin-bottom: 14px; font-weight: 400; font-size: 1.05rem; color: var(--accent); }

.chart-bars { display: flex; align-items: flex-end; justify-content: space-between; height: 140px; gap: 8px; }

.bar-wrap { flex: 1 1 0%; display: flex; flex-direction: column; align-items: center; gap: 6px; }

.bar { width: 100%; background: linear-gradient(to top,var(--accent),rgba(255,255,255,0.3)); border-radius: 8px 8px 4px 4px; transition: height 0.5s; min-height: 4px; }

.bar-label { font-size: 0.75rem; opacity: 0.8; }

.bar-val { font-size: 0.7rem; opacity: 0.9; font-weight: 600; }

.badges-panel { width: 100%; background: var(--panel-bg); border-radius: 20px; padding: 20px; margin-bottom: 18px; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }

.badges-panel h4 { margin-bottom: 14px; font-weight: 400; font-size: 1.05rem; color: var(--accent); }

.badges-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }

.badge-item { display: flex; align-items: center; gap: 12px; background: rgba(255, 255, 255, 0.05); border-radius: 14px; padding: 12px; transition: 0.3s; border: 1px solid rgba(255, 255, 255, 0.08); }

.badge-item:hover { background: rgba(255, 255, 255, 0.1); transform: translateY(-2px); }

.badge-item.locked { opacity: 0.4; }

.badge-icon { font-size: 2rem; line-height: 1; }

.badge-info { display: flex; flex-direction: column; }

.badge-title { font-size: 0.9rem; font-weight: 600; }

.badge-desc { font-size: 0.75rem; opacity: 0.75; margin-top: 2px; }

.reminder-panel { width: 100%; background: var(--panel-bg); border-radius: 20px; padding: 20px; margin-bottom: 18px; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }

.reminder-panel h4 { margin-bottom: 14px; font-weight: 400; font-size: 1.05rem; color: var(--accent); }

.reminder-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }

.reminder-row input[type="time"] { background: rgba(255, 255, 255, 0.12); border: 1px solid rgba(255, 255, 255, 0.3); color: rgb(255, 255, 255); padding: 8px 12px; border-radius: 10px; font-size: 1rem; }

.reminder-row input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(1); }

.toggle-switch { width: 44px; height: 24px; background: rgba(255, 255, 255, 0.2); border-radius: 12px; position: relative; cursor: pointer; transition: background 0.3s; }

.toggle-switch.on { background: var(--accent); }

.toggle-switch::after { content: ""; position: absolute; width: 18px; height: 18px; background: rgb(255, 255, 255); border-radius: 50%; top: 3px; left: 3px; transition: transform 0.3s; }

.toggle-switch.on::after { transform: translateX(20px); }

.reminder-msg { width: 100%; background: rgba(255, 215, 0, 0.15); border: 1px solid rgba(255, 215, 0, 0.4); border-radius: 14px; padding: 14px 18px; margin-top: 10px; font-size: 0.95rem; display: none; }

.reminder-msg.show { display: block; animation: 0.4s ease 0s 1 normal none running popIn; }

@keyframes popIn { 
  0% { opacity: 0; transform: translateY(-10px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.export-row { display: flex; gap: 10px; width: 100%; margin-bottom: 18px; justify-content: center; }

.export-btn { background: var(--btn-bg); border: 1px solid rgba(255, 255, 255, 0.3); color: rgb(255, 255, 255); padding: 12px 24px; border-radius: 25px; cursor: pointer; transition: 0.3s; font-size: 0.95rem; }

.export-btn:hover { background: rgba(255, 255, 255, 0.2); transform: translateY(-2px); }

.stars { position: fixed; width: 100%; height: 100%; pointer-events: none; overflow: hidden; top: 0px; left: 0px; z-index: -1; }

.star { position: absolute; background: white; border-radius: 50%; opacity: 0.3; animation: 3s ease-in-out 0s infinite normal none running twinkle; }

@keyframes twinkle { 
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

.particle { position: absolute; border-radius: 50%; background: var(--accent); opacity: 0.2; pointer-events: none; animation: 8s ease-in-out 0s infinite normal none running float; }

@keyframes float { 
  0%, 100% { transform: translateY(0px) translateX(0px); }
  33% { transform: translateY(-20px) translateX(10px); }
  66% { transform: translateY(10px) translateX(-10px); }
}

@media (max-width: 480px) {
  .main-stage { width: 250px; height: 250px; }
  .timer-ring, .timer-progress { width: 220px; height: 220px; }
  .timer-display { font-size: 3rem; }
  h1 { font-size: 1.6rem; }
  .technique-btn { padding: 10px 16px; font-size: 0.85rem; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .badges-grid { grid-template-columns: 1fr; }
}
